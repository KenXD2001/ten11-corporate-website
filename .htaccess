RewriteEngine On

# Handle Next.js static export routing for clean URLs
# If the requested file doesn't exist, try adding .html extension

# Specific rule for career job pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ten11/careers/job/([0-9]+)$ /ten11/careers/job/$1.html [L]

# Specific rule for presence pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ten11/presence/([a-zA-Z0-9-]+)$ /ten11/presence/$1.html [L]

# General rule for all other pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ten11/(.*)$ /ten11/$1.html [L]
